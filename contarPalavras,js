const palavras = ["maçã", "banana", "maçã", "laranja", "banana", "maçã"];

const contagem = palavras.reduce((relatorio, palavraAtual) => {
    // 1. Verifica se a palavra já existe no nosso objeto relatório
    if (relatorio[palavraAtual]) {
        // Se já existe, soma +1 ao contador dela
        relatorio[palavraAtual] += 1;
    } else {
        // Se é a primeira vez que a palavra aparece, inicia ela com o valor 1
        relatorio[palavraAtual] = 1;
    }
    
    // 2. Sempre retorne o objeto atualizado para a próxima rodada!
    return relatorio;
}, {}); // <--- O objeto vazio {} é o nosso ponto de partida (Valor Inicial)

console.log(contagem);
// Output: { maçã: 3, banana: 2, laranja: 1 }
